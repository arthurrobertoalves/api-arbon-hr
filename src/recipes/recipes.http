POST http://localhost:3000/recipes
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "title":"Chocolate Cake",
  "description": "Simple chocolate cake",
  "ingredients": "Flour, sugar, cocoa, eggs",
